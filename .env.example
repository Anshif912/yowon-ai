# -----------------------------------------------------------------------------
# YOWON AI — Production Environment Variables Configuration Template
# -----------------------------------------------------------------------------

# API Configuration & Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
GITHUB_TOKEN=your_github_token_here
GEMINI_API_KEY=your_google_gemini_api_key_here

# LLM Models Config
MODEL_NAME=qwen3:8b
OLLAMA_SPECIALIST_MODEL=qwen2.5:7b
OLLAMA_CHIEF_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=qwen2.5:3b
CHIEF_MODEL_CHAIN=deepseek-r1:8b,qwen2.5:7b,qwen2.5:3b

# Services Connectivity
# Inside docker-compose network, these point to service container hostnames
OLLAMA_HOST=http://ollama:11434
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Persistence & Storage Locations
DATABASE_URL=sqlite:////app/database/yowon.db
UPLOAD_DIR=/app/uploads
REPORT_DIR=/app/reports
REPOSITORY_CACHE_DIR=/app/repository_cache

# System Optimization & Sizing Limits
LOG_LEVEL=INFO
WORKER_THREADS=4
OLLAMA_PARALLEL=2
AGENT_TIMEOUT_SEC=600
EVALUATION_TIMEOUT_SEC=3600
MAX_CONTEXT_CHARS=6000
MAX_BRIEF_CHARS=1200
MAX_AGENT_DIGEST_CHARS=2500
