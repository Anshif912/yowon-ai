# ====================================================================
# YOWON AI - Enterprise Production Gitignore
# ====================================================================

# ── Python ──────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
pip-log.txt

# ── Node.js ─────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn-clean
.eslintcache

# ── React/Vite ──────────────────────────────────────────────────────
frontend/dist/
dist/
build/
.vite/

# ── Docker ──────────────────────────────────────────────────────────
.docker/
docker-data/

# ── Operating System ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.iml
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── Runtime ─────────────────────────────────────────────────────────
logs/
*.log
temp/
tmp/
generated/
artifacts/

# ── Databases ───────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/chroma_db/
chroma_db/

# ── Generated Reports ───────────────────────────────────────────────
backend/reports/yowon_report_*.pdf
backend/reports/*.pdf

# ── Repository Intelligence Cache ───────────────────────────────────
repository_cache/
analysis_cache/
backend/repository_cache/
backend/vector_cache/
backend/embedding_cache/
backend/model_cache/

# ── Uploads ─────────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/pdfs/
!backend/uploads/pdfs/.gitkeep
!backend/uploads/ppts/
!backend/uploads/ppts/.gitkeep
!backend/uploads/repos/
!backend/uploads/repos/.gitkeep

# ── Testing ─────────────────────────────────────────────────────────
.nyc_output/
coverage/

# ── Media & Legacy Reference (Untracked) ────────────────────────────
dribbble_shot.mp4
HA Frontend.zip
ha_frontend_ref/

# ── Local Environment ───────────────────────────────────────────────
.env
.env.local
*.local
.env.*
!.env.example
rewrite.py
git_rewrite.py